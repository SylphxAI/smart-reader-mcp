{
  "name": "@sylphx/smart-reader-mcp",
  "version": "0.1.0",
  "description": "One MCP call reads PDF, image, or video by sniffing format and delegating to Sylphx Reader siblings.",
  "type": "module",
  "private": true,
  "license": "MIT",
  "bin": {
    "smart-reader-mcp": "./dist/index.js"
  },
  "files": [
    "dist/",
    "README.md",
    "LICENSE"
  ],
  "exports": {
    ".": "./dist/index.js"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/SylphxAI/smart-reader-mcp.git"
  },
  "homepage": "https://github.com/SylphxAI/smart-reader-mcp#readme",
  "keywords": [
    "mcp",
    "model-context-protocol",
    "reader",
    "evidence",
    "sylphx",
    "pdf",
    "image",
    "video"
  ],
  "engines": {
    "node": ">=22.13.0"
  },
  "scripts": {
    "build": "tsc --project tsconfig.build.json",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "test": "bun test",
    "test:watch": "bun test --watch",
    "validate": "bun run typecheck && bun run build && bun run test"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "zod": "^4.4.3"
  },
  "optionalDependencies": {
    "@sylphx/pdf-reader-mcp": "*",
    "@sylphx/image-reader-mcp": "*",
    "@sylphx/video-reader-mcp": "*"
  },
  "devDependencies": {
    "@types/node": "^25.9.1",
    "bun-types": "^1.3.12",
    "typescript": "^7.0.2"
  },
  "packageManager": "bun@1.3.12"
}