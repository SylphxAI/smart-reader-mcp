{
  "name": "@sylphx/smart-reader-mcp",
  "version": "0.1.1",
  "mcpName": "io.github.SylphxAI/smart-reader-mcp",
  "description": "One MCP call reads PDF, image, or video by sniffing format and delegating to Sylphx Reader siblings.",
  "type": "module",
  "publishConfig": {
    "access": "public"
  },
  "license": "MIT",
  "bin": {
    "smart-reader-mcp": "./dist/index.js"
  },
  "files": [
    "dist/",
    "README.md",
    "LICENSE"
  ],
  "exports": {
    ".": "./dist/index.js"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/SylphxAI/smart-reader-mcp.git"
  },
  "homepage": "https://github.com/SylphxAI/smart-reader-mcp#readme",
  "keywords": [
    "mcp",
    "model-context-protocol",
    "reader",
    "evidence",
    "sylphx",
    "pdf",
    "image",
    "video"
  ],
  "engines": {
    "node": ">=22.13.0"
  },
  "scripts": {
    "build": "tsc --project tsconfig.build.json",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "test": "bun test",
    "test:watch": "bun test --watch",
    "check": "biome check .",
    "check:fix": "biome check --write .",
    "sync:server-json": "bun scripts/sync-server-json.ts",
    "version-packages": "changeset version && bun run sync:server-json",
    "validate": "bun run check && bun run typecheck && bun run build && bun run test",
    "doctor": "bun run src/index.ts doctor",
    "benchmark:release-gate": "bun scripts/release-gate.ts",
    "clean": "rm -rf dist coverage",
    "prepublishOnly": "bun run clean && bun run build",
    "release": "bun run typecheck && bun run check && bun run build && bun test && changeset publish"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "zod": "^4.4.3"
  },
  "optionalDependencies": {
    "@sylphx/pdf-reader-mcp": "3.0.14",
    "@sylphx/image-reader-mcp": "0.1.0",
    "@sylphx/video-reader-mcp": "0.1.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.16",
    "@changesets/changelog-github": "^0.7.0",
    "@changesets/cli": "^2.31.0",
    "@types/node": "^25.9.1",
    "bun-types": "^1.3.12",
    "typescript": "^7.0.2"
  },
  "packageManager": "bun@1.3.12"
}
