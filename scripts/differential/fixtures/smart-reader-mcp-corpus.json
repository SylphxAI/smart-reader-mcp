{
  "corpusVersion": 1,
  "toolRouteCases": [
    {
      "id": "route-read-media",
      "tool": "read_media",
      "expect": "RustCore"
    }
  ],
  "serverContract": {
    "name": "smart-reader-mcp",
    "version": "0.1.1",
    "tools": ["read_media"]
  },
  "toolCases": [
    {
      "id": "tool-unsupported",
      "fixture": "unsupported/plain.txt",
      "expect": {
        "status": "error",
        "message_contains": "Unsupported"
      }
    },
    {
      "id": "tool-pdf",
      "fixture": "sample.pdf",
      "mockReader": "pdf",
      "expect": {
        "status": "ok",
        "delegated_tool": "read_pdf",
        "detected_format": "pdf",
        "selected_category": "pdf",
        "result": {
          "pages": 1,
          "title": "golden-pdf"
        }
      }
    },
    {
      "id": "tool-image",
      "fixture": "sample.png",
      "mockReader": "image",
      "expect": {
        "status": "ok",
        "delegated_tool": "read_image",
        "detected_format": "image/png",
        "selected_category": "image",
        "result": {
          "mime": "image/png",
          "width": 1,
          "height": 1
        }
      }
    }
  ],
  "mockReaders": {
    "pdf": {
      "raw_result": { "pages": 1, "title": "golden-pdf" },
      "cli_response": {
        "status": "ok",
        "result": {
          "content": [{ "text": "{\"pages\":1,\"title\":\"golden-pdf\"}" }]
        }
      }
    },
    "image": {
      "raw_result": { "mime": "image/png", "width": 1, "height": 1 },
      "cli_response": {
        "status": "ok",
        "result": {
          "content": [{ "text": "{\"mime\":\"image/png\",\"width\":1,\"height\":1}" }]
        }
      }
    }
  },
  "allowList": {
    "tools": ["read_media"],
    "note": "fail-closed: only proven tool surface; no HTTP transport claimed on this slice"
  }
}
