{
  "profile": "smart_reader_read_media_golden",
  "description": "Golden envelope contract for read_media with mocked sibling reader CLI outputs.",
  "mock_readers": {
    "pdf": {
      "response": {
        "status": "ok",
        "result": {
          "content": [
            {
              "text": "{\"pages\":1,\"title\":\"golden-pdf\"}"
            }
          ]
        }
      },
      "raw_result": {
        "pages": 1,
        "title": "golden-pdf"
      }
    },
    "image": {
      "response": {
        "status": "ok",
        "result": {
          "content": [
            {
              "text": "{\"mime\":\"image/png\",\"width\":1,\"height\":1}"
            }
          ]
        }
      },
      "raw_result": {
        "mime": "image/png",
        "width": 1,
        "height": 1
      }
    },
    "video": {
      "response": {
        "status": "ok",
        "twin": {
          "streams": [
            {
              "codec": "h264"
            }
          ]
        }
      },
      "raw_result": {
        "streams": [
          {
            "codec": "h264"
          }
        ]
      }
    }
  },
  "cases": [
    {
      "id": "pdf",
      "fixture": "sample.pdf",
      "mock_reader": "pdf",
      "expects": {
        "status": "ok",
        "route": "rust-read-media-v1",
        "envelope": {
          "locator": {
            "detectedFormat": "pdf"
          },
          "route": {
            "sniff": "rust-sniff",
            "delegation": "read_pdf"
          },
          "delegation": {
            "contract_version": "smart-reader-delegation-v1",
            "delegated_tool": "read_pdf",
            "detected_format": "pdf",
            "reader_package": "@sylphx/pdf-reader-mcp",
            "reader_contract_version": "3.0.14"
          },
          "routing": {
            "contract_version": "smart-reader-delegation-v1",
            "selected_category": "pdf",
            "sniff_method": "rust-sniff",
            "launch_source": "local",
            "reader_package": "@sylphx/pdf-reader-mcp",
            "declared_extension": ".pdf"
          },
          "warnings": [],
          "result": {
            "pages": 1,
            "title": "golden-pdf"
          }
        }
      }
    },
    {
